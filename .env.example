# Copie para .env e preencha (nunca commite .env)
# Modo Gmail: pip install -r requirements-gmail.txt

# Query de busca no Gmail (padrão: não lidos com termos de NF)
GMAIL_SEARCH_QUERY=is:unread ("nota fiscal" OR "NF-e" OR nfe OR fatura OR boleto OR invoice)

# Horários de execução automática (modo agendado) — formato HH:MM separados por vírgula
SCHEDULE_TIMES=09:00,12:00

# Label aplicada após processar com sucesso
LABEL_PROCESSED=BOT/NF_PROCESSADA

# Ambiente
ENV=demo
